{
  "name": "bellamem",
  "version": "0.3.0-alpha.2",
  "description": "Local accumulating memory for LLM coding agents — Node port of v0.2",
  "type": "module",
  "bin": {
    "bellamem": "./dist/bin/bellamem.js",
    "bella": "./dist/bin/bellamem.js",
    "bellamem-guard": "./dist/bin/bellamem-guard.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -p . --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node --loader tsx ./bin/bellamem.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "commander": "^12.1.0",
    "env-paths": "^3.0.0",
    "hono": "^4.12.14",
    "open": "^11.0.0",
    "openai": "^4.77.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
