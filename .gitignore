# Secrets — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtualenvs
.venv/
venv/
env/
ENV/

# Packaging / build
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Tests / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# bellamem runtime state — per-project graph lives in .graph/ by default.
# Gitignored so a repo's history doesn't carry its belief graph; users who
# want to commit their graph can remove this line explicitly.
.graph/
data/
snapshots/
*.snapshot.json
embed_cache.json
llm_ew_cache.json

# Claude Code session transcripts (if ever materialised inside the repo)
*.jsonl
