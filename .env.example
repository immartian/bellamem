# bellamem configuration — copy to .env and fill in your own values.
#
# The default (no .env at all) uses the zero-dep HashEmbedder and
# regex-only EW. Everything below is opt-in upgrades.
#
# Never commit .env. .gitignore already excludes it.

# ---------------------------------------------------------------------------
# Embedder
# ---------------------------------------------------------------------------

# Which embedder to use: hash | st | openai
#   hash    — stdlib-only character trigrams (zero-dep default)
#   st      — sentence-transformers (pip install bellamem[st])
#   openai  — OpenAI API (pip install bellamem[openai])
BELLAMEM_EMBEDDER=hash

# Model id. Ignored by the hash backend. Sensible defaults:
#   st      → all-MiniLM-L6-v2
#   openai  → text-embedding-3-small
# BELLAMEM_EMBEDDER_MODEL=text-embedding-3-small

# Cache embeddings to disk (recommended for openai/st, ignored for hash)
# BELLAMEM_EMBEDDER_CACHE=1
# BELLAMEM_EMBEDDER_CACHE_PATH=.graph/embed_cache.json


# ---------------------------------------------------------------------------
# LLM-backed EW (optional, for CAUSE + self-observation extraction)
# ---------------------------------------------------------------------------

# regex | hybrid
#   regex   — default, zero LLM calls
#   hybrid  — regex path plus LLM extraction for structural cases
#             (requires OPENAI_API_KEY and [openai] extra)
# BELLAMEM_EW=regex

# BELLAMEM_EW_LLM_MODEL=gpt-4o-mini
# BELLAMEM_EW_LLM_CACHE_PATH=.graph/llm_ew_cache.json


# ---------------------------------------------------------------------------
# API keys (only if you opted in to openai-backed components above)
# ---------------------------------------------------------------------------

# OPENAI_API_KEY=sk-...


# ---------------------------------------------------------------------------
# Snapshot path override (default: <project>/.graph/default.json)
# ---------------------------------------------------------------------------
#
# The graph lives per-project inside `.graph/` in the git repo root.
# Override this if you want a shared tree across projects, or a custom
# location. Prior to v0.0.3 the default was `~/.bellamem/default.json`;
# `bellamem migrate` copies legacy state into the new per-project path.

# BELLAMEM_SNAPSHOT=.graph/default.json
